<Window x:Class="AutoDataEntryProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="محرك إدخال البيانات التلقائي - مشروع التخرج" 
        Height="650" Width="700" 
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FlowDirection="RightToLeft">
    
    <Window.Resources>
        <!-- أنماط الأزرار -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- عنوان المشروع -->
        <Border Grid.Row="0" Background="#2196F3" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="نظام إدخال البيانات التلقائي" 
                          FontSize="18" 
                          FontWeight="Bold" 
                          Foreground="White" 
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Automated Data Entry System" 
                          FontSize="11" 
                          Foreground="#E3F2FD" 
                          HorizontalAlignment="Center"
                          Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- قسم اختيار الملفات -->
        <GroupBox Header="⚙ إعدادات الملفات" Grid.Row="1" Style="{StaticResource GroupBoxStyle}">
            <StackPanel>
                <!-- اختيار ملف Excel -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ملف Excel:" 
                              VerticalAlignment="Center" 
                              FontWeight="SemiBold"
                              Grid.Column="0"/>
                    <TextBox x:Name="txtExcelPath" 
                            Grid.Column="1" 
                            IsReadOnly="True" 
                            Background="#F9F9F9"
                            Padding="8"
                            VerticalAlignment="Center"
                            Margin="5,0"/>
                    <Button Content="استعراض" 
                           Grid.Column="2" 
                           Click="btnSelectExcel_Click"
                           Style="{StaticResource ModernButton}"
                           Background="#4CAF50"
                           Foreground="White"
                           Width="100"/>
                </Grid>

                <!-- اختيار التطبيق الهدف -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="التطبيق الهدف:" 
                              VerticalAlignment="Center" 
                              FontWeight="SemiBold"
                              Grid.Column="0"/>
                    <TextBox x:Name="txtAppPath" 
                            Grid.Column="1" 
                            IsReadOnly="True" 
                            Background="#F9F9F9"
                            Padding="8"
                            VerticalAlignment="Center"
                            Margin="5,0"/>
                    <Button Content="استعراض" 
                           Grid.Column="2" 
                           Click="btnSelectTargetApp_Click"
                           Style="{StaticResource ModernButton}"
                           Background="#2196F3"
                           Foreground="White"
                           Width="100"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- قسم معلومات البيانات -->
        <GroupBox Header="📊 معلومات البيانات" Grid.Row="2" Style="{StaticResource GroupBoxStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="إجمالي الطلاب" 
                              FontSize="11" 
                              Foreground="Gray" 
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblTotalCount" 
                              Text="0" 
                              FontSize="22" 
                              FontWeight="Bold" 
                              Foreground="#2196F3"
                              HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="تم المعالجة" 
                              FontSize="11" 
                              Foreground="Gray"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblProcessedCount" 
                              Text="0" 
                              FontSize="22" 
                              FontWeight="Bold" 
                              Foreground="#4CAF50"
                              HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="الوقت المستغرق" 
                              FontSize="11" 
                              Foreground="Gray"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblElapsedTime" 
                              Text="00:00" 
                              FontSize="22" 
                              FontWeight="Bold" 
                              Foreground="#FF9800"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- قسم التحكم -->
        <GroupBox Header="🎮 التحكم في العملية" Grid.Row="3" Style="{StaticResource GroupBoxStyle}">
            <StackPanel>
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnStart" 
                           Content="▶ بدء الأتمتة" 
                           Click="btnStartAutomation_Click" 
                           Grid.Column="0" 
                           Margin="0,0,5,0" 
                           Height="45" 
                           Background="#4CAF50" 
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="14"
                           Style="{StaticResource ModernButton}"/>
                    <Button x:Name="btnStop" 
                           Content="⏹ إيقاف" 
                           Click="btnStop_Click" 
                           Grid.Column="1" 
                           Margin="5,0,0,0" 
                           Height="45" 
                           Background="#F44336" 
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="14"
                           IsEnabled="False"
                           Style="{StaticResource ModernButton}"/>
                </Grid>
                
                <ProgressBar x:Name="progressBar" 
                            Height="25" 
                            Margin="0,15,0,8"
                            Minimum="0"
                            Maximum="100"/>
                <TextBlock x:Name="lblProgress" 
                          Text="جاهز للبدء" 
                          HorizontalAlignment="Center" 
                          FontWeight="SemiBold"
                          FontSize="12"
                          Foreground="#666"/>
            </StackPanel>
        </GroupBox>

        <!-- سجل العمليات -->
        <GroupBox Header="📝 سجل العمليات (Log)" Grid.Row="4" Style="{StaticResource GroupBoxStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="txtLog" 
                        IsReadOnly="True" 
                        Background="#1E1E1E" 
                        Foreground="#00FF00" 
                        FontFamily="Consolas" 
                        FontSize="11" 
                        Padding="10"
                        TextWrapping="Wrap"
                        BorderThickness="0"
                        VerticalScrollBarVisibility="Auto"/>
            </ScrollViewer>
        </GroupBox>

        <!-- شريط الحالة السفلي -->
        <Border Grid.Row="5" 
                Background="#2196F3" 
                CornerRadius="5" 
                Padding="10,8"
                Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblStatus" 
                          Text="● جاهز" 
                          Foreground="White" 
                          VerticalAlignment="Center"
                          FontSize="11"/>
                <TextBlock Grid.Column="1" 
                          Text="Graduation Project 2024" 
                          Foreground="#E3F2FD" 
                          VerticalAlignment="Center"
                          FontSize="10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
